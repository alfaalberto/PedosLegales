rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Cada usuario solo puede leer/escribir sus propios archivos
    match /users/{userId}/blobs/{blobId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Ningún otro acceso permitido
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
