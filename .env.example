# Copia como .env y agrega tu API key.
# NUNCA pongas la API key dentro del HTML.

OPENAI_API_KEY=sk-proj-REEMPLAZA_ESTO

MODEL_POLICY_MODE=auto
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=high
OPENAI_VERBOSITY=medium
OPENAI_MAX_OUTPUT_TOKENS=6000

# Protecciones de tamaño
MAX_PACKET_CHARS=220000
MAX_CHUNKS_PER_REQUEST=30
MAX_CHUNK_CHARS=5000

# Web search está apagado por defecto para proteger datos.
ALLOW_WEB_SEARCH=false

PORT=8787


# v7 offline-first
# true = sirve PDF.js/Tesseract desde /public/vendor si corriste npm run prepare:offline
# false = permite fallback CDN desde frontend
OFFLINE_VENDOR_MODE=true

# Cifrado local en frontend: se activa desde la interfaz con contraseña maestra.
# No se guarda la contraseña.

# Límites de seguridad/exportación
MAX_EXPORT_CHARS=500000
MAX_PACKET_CHARS=220000
MAX_CHUNKS_PER_REQUEST=30
MAX_CHUNK_CHARS=5000
